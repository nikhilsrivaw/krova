# ═══════════════════════════════════════════════════════════════════════════════
# KROVA — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git. It contains secrets.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────────
ENVIRONMENT=development                    # development | staging | production
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_NAME=KROVA
APP_VERSION=0.1.0

# ── Database ───────────────────────────────────────────────────────────────────
# asyncpg driver required — note postgresql+asyncpg:// prefix
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/krova
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Supabase ───────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic ──────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_HAIKU_MODEL=claude-haiku-4-5
CLAUDE_SONNET_MODEL=claude-sonnet-4-5
CLAUDE_RATE_LIMIT_TPM=100000              # Tokens per minute — check your Anthropic tier

# ── Meta (WhatsApp + Instagram) ────────────────────────────────────────────────
# Get from: https://developers.facebook.com → Your App → Settings → Basic
META_APP_ID=
META_APP_SECRET=
# Choose any random string — you'll paste this into Meta webhook config
META_WEBHOOK_VERIFY_TOKEN=krova_webhook_secret_change_this
META_API_VERSION=v18.0

# ── Google (Gmail) ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_PUBSUB_TOPIC=projects/your-gcp-project/topics/gmail-notifications

# ── Microsoft (Outlook) ────────────────────────────────────────────────────────
# Get from: https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback
MICROSOFT_TENANT_ID=common

# ── Security ───────────────────────────────────────────────────────────────────
# Generate ENCRYPTION_KEY with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Generate JWT_SECRET with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=10080                  # 7 days — owner stays logged in on mobile

# ── Monitoring ─────────────────────────────────────────────────────────────────
# Get from: https://sentry.io → Settings → Projects → Client Keys
# Leave empty in development — Sentry is optional locally
SENTRY_DSN=

# ── n8n Automation ─────────────────────────────────────────────────────────────
# Leave empty if running locally without n8n
N8N_BASE_URL=
N8N_API_KEY=

# ── Rate Limiting ──────────────────────────────────────────────────────────────
API_RATE_LIMIT_PER_MINUTE=60
WEBHOOK_RATE_LIMIT_PER_MINUTE=1000
